generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Season {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  games     Game[]
}

model Player {
  id        String    @id @default(cuid())
  name      String
  age       Int
  imageUrl  String?
  createdAt DateTime  @default(now())
  deletedAt DateTime? // For soft delete

  gamesAsP1 Game[] @relation("Player1Games")
  gamesAsP2 Game[] @relation("Player2Games")
}

model Game {
  id            String   @id @default(cuid())
  player1Id     String
  player2Id     String
  player1Result String
  session       String
  comment       String?
  playedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  seasonId      String?

  player1 Player  @relation("Player1Games", fields: [player1Id], references: [id])
  player2 Player  @relation("Player2Games", fields: [player2Id], references: [id])
  season  Season? @relation(fields: [seasonId], references: [id])
}
